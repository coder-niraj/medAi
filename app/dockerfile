FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1
WORKDIR /app

# System dependencies for Postgres and PDF handling
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    libmagic1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt . 
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Use the PORT env var but default to 3001 for your compose setup
CMD ["sh", "-c", "uvicorn main:fast_app --host 0.0.0.0 --port ${PORT:-3001}"]