FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1
WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Fix 1: You need a dot after requirements.txt to tell it WHERE to copy
COPY requirements.txt . 
RUN pip install --no-cache-dir -r requirements.txt

# Fix 2: "COPY .. " is a typo. It should be "COPY . ." (space between the dots)
COPY . .

# Fix 3: Based on your screenshot, your entry file is app.py inside the app folder
CMD ["uvicorn", "main:fast_app", "--host", "0.0.0.0", "--port", "3001"]